# Slskd connection
SLSKD_HOST=http://slskd:5030
SLSKD_API_KEY=none

# Quality filter (comma-separated bitrates, leave blank to accept all MP3 bitrates)
TARGET_BITRATES=320

# Performance
MAX_WORKERS=10
MAX_RETRIES=3

# Wait times between search attempts (seconds)
WAIT_TIMES=15,25,35

# Transfer verification delay (seconds)
TRANSFER_CHECK_DELAY=5
